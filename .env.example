# AI Trends Dashboard Configuration

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data

# API Settings
API_TIMEOUT=10
API_RETRY_COUNT=3
API_RETRY_DELAY=5

# Feature Flags
DEBUG=false
USE_CACHE=true
CACHE_EXPIRY_HOURS=24

# Dashboard
REFRESH_INTERVAL=3600
MAX_ITEMS_PER_CATEGORY=6

# Sources
GOOGLE_NEWS_LIMIT=15
HACKER_NEWS_LIMIT=10
PRODUCT_HUNT_LIMIT=10
REDDIT_LIMIT=10

# Performance
HACKER_NEWS_MAX_WORKERS=5
REQUEST_TIMEOUT=10

# Environment
ENVIRONMENT=production
